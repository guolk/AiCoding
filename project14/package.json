{
  "name": "react-performance-demo",
  "version": "1.0.0",
  "description": "React应用性能优化演示项目",
  "main": "index.js",
  "sideEffects": [
    "*.css",
    "*.scss",
    "*.less"
  ],
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production",
